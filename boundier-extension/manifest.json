{
  "manifest_version": 3,
  "name": "Boundier",
  "version": "2.0",
  "description": "Local-first influence-pressure analysis with Rustmeter scoring.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "Readability.js",
        "extractor.js",
        "content.js"
      ]
    }
  ]
}